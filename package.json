{
    "name": "krit",
    "version": "0.1.0",
    "description": "AI-powered terminal",
    "author": {
        "name": "Kritesh Goud",
        "email": "kritesh@example.com"
    },
    "main": "src/main/index.js",
    "scripts": {
        "start": "electron . --disable-gpu",
        "dev": "electron . --dev",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.kritesh.krit",
        "productName": "Krit",
        "directories": {
            "output": "dist",
            "buildResources": "build"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ]
        },
        "win": {
            "target": "nsis"
        },
        "mac": {
            "target": "dmg"
        }
    },
    "dependencies": {
        "dotenv": "^16.6.1",
        "node-pty": "^1.1.0",
        "openai": "^6.34.0",
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0"
    },
    "devDependencies": {
        "electron": "^29.0.0",
        "electron-builder": "^26.8.1"
    }
}
